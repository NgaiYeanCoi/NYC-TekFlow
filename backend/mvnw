#!/usr/bin/env sh
set -eu
BASE_DIR="$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)"
MAVEN_DIR="$BASE_DIR/.mvn/wrapper/apache-maven-3.9.11"
MAVEN_CMD="$MAVEN_DIR/bin/mvn"

if [ ! -x "$MAVEN_CMD" ]; then
  mkdir -p "$BASE_DIR/.mvn/wrapper"
  ZIP="$BASE_DIR/.mvn/wrapper/apache-maven-3.9.11-bin.zip"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "https://archive.apache.org/dist/maven/maven-3/3.9.11/binaries/apache-maven-3.9.11-bin.zip" -o "$ZIP"
  else
    wget -q "https://archive.apache.org/dist/maven/maven-3/3.9.11/binaries/apache-maven-3.9.11-bin.zip" -O "$ZIP"
  fi
  unzip -q "$ZIP" -d "$BASE_DIR/.mvn/wrapper"
fi

exec "$MAVEN_CMD" "$@"

